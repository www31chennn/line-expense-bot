# （選用）正式環境開啟 /test 測試頁用；本機開發不需要設。
# 這個開關會讓 /api/test-parse 在 production 可被呼叫，該 API 可指定任意 userId，開完務必移除
# ALLOW_TEST_PAGE=true

# Gemini API Key（在 aistudio.google.com/apikey 免費建立，不用信用卡）
GEMINI_API_KEY=xxxxxxxxxxxxxxxx

# LINE Messaging API（LINE Developers Console -> 你的 Channel -> Basic settings / Messaging API）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxx

# Firebase 服務帳戶（Firebase Console -> 專案設定 -> 服務帳戶 -> 產生新的私密金鑰）
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n貼上完整內容\n-----END PRIVATE KEY-----\n"